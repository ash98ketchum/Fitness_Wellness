generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Gym {
  id             String   @id @default(uuid())
  name           String
  brandingColor  String?  @default("#000000")
  logoUrl        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             String   @default("MEMBER")
  gymId            String?
  gym              Gym?     @relation(fields: [gymId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  onboardingProfile OnboardingProfile?
  dietPlans         DietPlan[]
  longTermGoal      LongTermGoal?
  dailyProgresses   DailyProgress[]
  mealLogs          MealLog[]
  userMemory        UserMemory?
}

model OnboardingProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  personalInfo     String   // JSON stored as text for SQLite
  fitnessGoals     String
  lifestyle        String
  healthData       String
  foodPreferences  String
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DietPlan {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  status            String   @default("GENERATING")
  
  totalCalories     Int?
  proteinG          Int?
  carbsG            Int?
  fatsG             Int?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  meals             Meal[]
  verificationReport VerificationReport?
}

model Meal {
  id                String   @id @default(uuid())
  dietPlanId        String
  dietPlan          DietPlan @relation(fields: [dietPlanId], references: [id])
  
  name              String
  description       String?
  time              String?
  
  calories          Int
  macros            String   // JSON as text
  ingredients       String   // JSON as text
  
  prepTime          Int?     // in minutes
  difficulty        String?  // e.g. "Easy", "Medium", "Hard"
  portionSizes      String?  // JSON as text
  recipeSteps       String?  // JSON as text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  mealLogs          MealLog[]
}

model VerificationReport {
  id                String   @id @default(uuid())
  dietPlanId        String   @unique
  dietPlan          DietPlan @relation(fields: [dietPlanId], references: [id])
  
  confidenceScore   Int
  issuesFound       String   // JSON as text
  correctionsApplied String  // JSON as text
  
  agent1Raw         String?
  agent2Raw         String?
  agent3Raw         String?
  
  createdAt         DateTime @default(now())
}

model LongTermGoal {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  targetWeight     Float?
  currentWeight    Float?
  goalDate         DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DailyProgress {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             String   // Storing as YYYY-MM-DD for easy querying in SQLite
  
  caloriesConsumed Int      @default(0)
  caloriesRemaining Int     @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([userId, date])
}

model MealLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  mealId           String?
  meal             Meal?    @relation(fields: [mealId], references: [id])
  
  status           String   @default("COMPLETED") // COMPLETED, SKIPPED, DEVIATED
  deviationNotes   String?  // e.g. "I ate ice cream at 11 PM"
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserMemory {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  favoriteFoods    String?  // JSON as text
  dislikes         String?  // JSON as text
  sicknessMode     Boolean  @default(false)
  sicknessNotes    String?  
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
