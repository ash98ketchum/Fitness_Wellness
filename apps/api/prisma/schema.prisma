generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

model Gym {
  id             String   @id @default(uuid())
  name           String
  brandingColor  String?  @default("#000000")
  logoUrl        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             String   @default("MEMBER")
  gymId            String?
  gym              Gym?     @relation(fields: [gymId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  onboardingProfile OnboardingProfile?
  dietPlans         DietPlan[]
  longTermGoal      LongTermGoal?
  dailyProgresses   DailyProgress[]
  mealLogs          MealLog[]
  userMemory        UserMemory?
  workoutSessions   WorkoutSession[]
  healthProfile     UserHealthProfile?
  transformationState TransformationState?
  eventLogs         EventLog[]
  aiDecisionLogs    AIDecisionLog[]
  streaks           Streak?
  vectorMemories    UserVectorMemory[]
}

model OnboardingProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  personalInfo     String   // JSON stored as text
  fitnessGoals     String
  lifestyle        String
  healthData       String
  foodPreferences  String
  
  // Expanded Phase 4 Fields
  bloodGroup       String?
  timeZone         String?
  occupation       String?
  diseases         String?  // JSON array
  allergies        String?  // JSON array
  medications      String?  // JSON array
  medicalReports   String?  // JSON array of file URLs
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DietPlan {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  status            String   @default("GENERATING")
  
  totalCalories     Int?
  proteinG          Int?
  carbsG            Int?
  fatsG             Int?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  meals             Meal[]
  verificationReport VerificationReport?
}

model Meal {
  id                String   @id @default(uuid())
  dietPlanId        String
  dietPlan          DietPlan @relation(fields: [dietPlanId], references: [id])
  
  name              String
  description       String?
  time              String?
  
  calories          Int
  macros            String   // JSON as text
  ingredients       String   // JSON as text
  
  prepTime          Int?     // in minutes
  difficulty        String?  // e.g. "Easy", "Medium", "Hard"
  portionSizes      String?  // JSON as text
  recipeSteps       String?  // JSON as text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  mealLogs          MealLog[]
}

model VerificationReport {
  id                String   @id @default(uuid())
  dietPlanId        String   @unique
  dietPlan          DietPlan @relation(fields: [dietPlanId], references: [id])
  
  confidenceScore   Int
  issuesFound       String   // JSON as text
  correctionsApplied String  // JSON as text
  
  agent1Raw         String?
  agent2Raw         String?
  agent3Raw         String?
  
  createdAt         DateTime @default(now())
}

model LongTermGoal {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  targetWeight     Float?
  currentWeight    Float?
  goalDate         DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DailyProgress {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             String   // Storing as YYYY-MM-DD for easy querying in SQLite
  
  caloriesConsumed Int      @default(0)
  caloriesRemaining Int     @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([userId, date])
}

model MealLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  mealId           String?
  meal             Meal?    @relation(fields: [mealId], references: [id])
  
  status           String   @default("COMPLETED") // COMPLETED, SKIPPED, DEVIATED
  deviationNotes   String?  // e.g. "I ate ice cream at 11 PM"
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserMemory {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  favoriteFoods    String?  // JSON as text
  dislikes         String?  // JSON as text
  sicknessMode     Boolean  @default(false)
  sicknessNotes    String?  
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// PHASE 3: WORKOUT SYSTEM
// ─────────────────────────────────────────────────────────

// Static Exercise Library
model Exercise {
  id               String   @id @default(uuid())
  name             String
  bodyPart         String
  targetMuscles    String   // JSON array
  secondaryMuscles String   // JSON array
  equipment        String
  difficulty       String
  setupAnimationUrl String?
  gripAnimationUrl  String?
  postureAnimationUrl String?
  movementAnimationUrl String?
  loopAnimationUrl  String?
  instructions     String   // JSON array of steps
  
  workouts         WorkoutExercise[]
}

// A generated workout for a specific day
model WorkoutSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             DateTime
  title            String   // e.g. "Chest + Triceps"
  status           String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, SKIPPED
  durationMinutes  Int?
  caloriesBurned   Int?
  
  exercises        WorkoutExercise[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Specific exercise within a workout
model WorkoutExercise {
  id               String   @id @default(uuid())
  workoutId        String
  workout          WorkoutSession @relation(fields: [workoutId], references: [id])
  exerciseId       String
  exercise         Exercise @relation(fields: [exerciseId], references: [id])
  
  order            Int
  setsTarget       Int
  repsTarget       String   // e.g., "10", "8-12", "Till Failure"
  restSeconds      Int      @default(90)
  suggestedWeight  Float?   // in kg
  tempo            String?  // e.g., "3-1-1"
  intensity        String?  // e.g., "Moderate", "RPE 8"
  
  sets             WorkoutSet[]
}

// Granular tracking of actual performance
model WorkoutSet {
  id               String   @id @default(uuid())
  workoutExerciseId String
  workoutExercise  WorkoutExercise @relation(fields: [workoutExerciseId], references: [id])
  
  setNumber        Int
  repsCompleted    Int?
  weightUsed       Float?
  isCompleted      Boolean  @default(false)
}

// User Health & Safety tracking
model UserHealthProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  activeInjuries   String   // JSON array e.g., ["Shoulder", "Lower Back"]
  recoveryScore    Int      @default(100) // 0-100
  fatigueLevel     String   @default("LOW")
  
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// PHASE 4: ADAPTIVE AI OPERATING SYSTEM
// ─────────────────────────────────────────────────────────

model TransformationState {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  
  goal                String   // "Fat Loss", "Muscle Gain", "Maintenance", etc.
  currentWeight       Float?
  lastWeightUpdate    DateTime @default(now())
  targetWeight        Float?
  estimatedCompletion DateTime?
  confidenceScore     Int      @default(0)
  weeklyAdherence     Int      @default(0)
  recoveryScore       Int      @default(0)
  currentPhase        String?  // e.g. "Fat Loss Phase 2"
  weeklyCalorieBudget Int      @default(0)
  remainingCalories   Int      @default(0)
  musclePriority      String   // JSON array of strings
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model EventLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  eventType        String   // e.g., "WORKOUT_SKIPPED", "CHEAT_MEAL", "MOOD_LOGGED"
  eventData        String   // JSON string with details
  source           String   @default("SYSTEM") // USER, SYSTEM, AGENT
  
  createdAt        DateTime @default(now())
}

model AIDecisionLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  reason           String   // The triggering event or context
  decision         String   // What the Master Coach decided
  impact           String   // E.g., "Completion delayed 1 day."
  confidence       Int      // 0-100
  
  createdAt        DateTime @default(now())
}

model Streak {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  
  workoutStreak    Int      @default(0)
  nutritionStreak  Int      @default(0)
  hydrationStreak  Int      @default(0)
  sleepStreak      Int      @default(0)
  overallConsistency Int    @default(0) // 0-100 score
  
  updatedAt        DateTime @updatedAt
}

// UserMemory was updated with pgvector support
// We will add the embedding field when we run postgres extension
model UserVectorMemory {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  content          String   // The text extracted from PDF or interaction
  metadata         String?  // JSON context
  embedding        String?  // JSON array of floats for local dev
  
  createdAt        DateTime @default(now())
}
